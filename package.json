{
  "name": "sermona-design-system",
  "private": true,
  "description": "Sermona design tokens, CSS primitives, VitePress handbook, and doc scaffold — dark editorial UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/mediapeople/sermona-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/mediapeople/sermona-design-system/issues"
  },
  "homepage": "https://sermonacss.com",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "dev": "npm run dev -w sermona-docs",
    "dev:docs": "npm run dev -w sermona-docs",
    "build:tokens": "npm run build -w @sermona/tokens",
    "build:docs": "npm run build -w sermona-docs",
    "build": "npm run build:tokens && npm run build:docs",
    "test": "node --test tests/*.test.mjs",
    "generate:share-assets": "node scripts/generate-share-assets.mjs",
    "bootstrap:docs": "node ./packages/create-sermona-docs/bin.mjs",
    "create-docs": "node ./packages/create-sermona-docs/bin.mjs",
    "export:provenance": "node ./scripts/export-provenance.mjs"
  }
}
