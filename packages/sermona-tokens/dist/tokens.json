{
  "meta": {
    "name": "Sermona",
    "source": "https://www.figma.com/design/IC2hBpxXtkX9Hzb5IMdwmh/Sermona",
    "fontNote": "Host product fonts under license. Swap stacks via --sermona-font-family-sans | display | mono on :root (see Tokens doc). Icon fonts: --sermona-icon-font-* + .sermona-icon--font."
  },
  "color": {
    "bg": {
      "page": "#1a1a1a",
      "elevated": "#202020",
      "slide": "#302b13",
      "card": "#202020"
    },
    "border": {
      "subtle": "#232323",
      "hairline": "rgba(255, 255, 255, 0.18)",
      "quote": "#414141",
      "meta": "#535353"
    },
    "text": {
      "primary": "#ffffff",
      "muted": "rgba(255, 255, 255, 0.6)",
      "subtle": "rgba(255, 255, 255, 0.48)",
      "inverse": "#1a1a1a"
    },
    "accent": {
      "primary": "#ffd600",
      "onAccent": "#1a1a1a"
    },
    "icon": {
      "default": "#ffffff",
      "muted": "rgba(255, 255, 255, 0.55)",
      "accent": "#ffd600",
      "inverse": "#1a1a1a"
    },
    "surface": {
      "iconTile": "rgba(32, 32, 32, 0.85)",
      "iconTileHover": "rgba(40, 40, 40, 1)",
      "scrim": "rgba(0, 0, 0, 0.45)"
    }
  },
  "font": {
    "family": {
      "sans": "\"Scto Grotesk A\", \"Helvetica Neue\", system-ui, -apple-system, sans-serif",
      "display": "\"Scto Grotesk A\", \"Helvetica Neue\", system-ui, -apple-system, sans-serif",
      "mono": "ui-monospace, \"SF Mono\", SFMono-Regular, Menlo, Consolas, monospace"
    },
    "weight": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "bold": 700
    },
    "size": {
      "displayUltraman": "168px",
      "displayMegaman": "118.8px",
      "h1": "72px",
      "h2": "42px",
      "h3": "32px",
      "h4": "24px",
      "body": "16px",
      "meta": "14px",
      "caption": "13px",
      "xs": "12px"
    },
    "lineHeight": {
      "tight": 1.25,
      "snug": 1.3,
      "heading": 1.35,
      "headingSnug": 1.2,
      "displayTight": 1.12,
      "body": 1.55,
      "relaxed": 1.75,
      "metaMax": 1.5,
      "caption": 1.45
    },
    "letterSpacing": {
      "uppercaseLabel": "0.04em",
      "meta": "0.02em"
    }
  },
  "space": {
    "0": "0",
    "1": "8px",
    "2": "10px",
    "3": "22px",
    "4": "24px",
    "5": "32px",
    "6": "40px",
    "7": "62px",
    "8": "65px",
    "9": "84px"
  },
  "radius": {
    "sm": "4px",
    "md": "8px",
    "full": "9999px"
  },
  "shadow": {
    "card": "1px 12px 10px rgba(0, 0, 0, 0.25)",
    "lift": "0 18px 40px rgba(0, 0, 0, 0.35)"
  },
  "icon": {
    "size": {
      "xs": "16px",
      "sm": "20px",
      "md": "24px",
      "lg": "32px",
      "xl": "48px",
      "display": "64px"
    },
    "tile": {
      "sm": "40px",
      "md": "48px",
      "lg": "56px",
      "xl": "72px"
    },
    "stroke": "1.5",
    "font": {
      "family": "inherit",
      "weight": "400",
      "style": "normal",
      "variationSettings": "normal"
    }
  },
  "layout": {
    "max": {
      "content": "732px",
      "wide": "960px",
      "full": "1200px"
    },
    "section": {
      "yTight": "48px",
      "yDefault": "72px",
      "yLoose": "96px"
    },
    "gap": {
      "cols": "65px",
      "iconRow": "32px"
    }
  },
  "motion": {
    "duration": {
      "fast": "150ms",
      "base": "250ms",
      "slow": "400ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "emphasis": "cubic-bezier(0.16, 1, 0.3, 1)"
    }
  },
  "typeRoles": {
    "display.light": {
      "fontFamily": "{font.family.display}",
      "fontWeight": "{font.weight.light}",
      "fontSize": "{font.size.displayUltraman}",
      "lineHeight": "{font.lineHeight.displayTight}",
      "textTransform": "capitalize"
    },
    "display.hero": {
      "fontFamily": "{font.family.display}",
      "fontWeight": "{font.weight.bold}",
      "fontSize": "{font.size.displayMegaman}",
      "lineHeight": "{font.lineHeight.displayTight}",
      "textTransform": "capitalize"
    },
    "heading.section": {
      "fontFamily": "{font.family.sans}",
      "fontWeight": "{font.weight.bold}",
      "fontSize": "{font.size.h2}",
      "lineHeight": "{font.lineHeight.headingSnug}",
      "textTransform": "capitalize"
    },
    "heading.block": {
      "fontFamily": "{font.family.sans}",
      "fontWeight": "{font.weight.bold}",
      "fontSize": "{font.size.h3}",
      "lineHeight": "{font.lineHeight.headingSnug}"
    },
    "body.default": {
      "fontFamily": "{font.family.sans}",
      "fontWeight": "{font.weight.regular}",
      "fontSize": "{font.size.body}",
      "lineHeight": "{font.lineHeight.body}"
    },
    "meta.default": {
      "fontFamily": "{font.family.sans}",
      "fontWeight": "{font.weight.regular}",
      "fontSize": "{font.size.caption}",
      "lineHeight": "{font.lineHeight.caption}",
      "color": "{color.text.subtle}"
    },
    "quote.body": {
      "fontFamily": "{font.family.sans}",
      "fontWeight": "{font.weight.medium}",
      "fontSize": "{font.size.h4}",
      "lineHeight": "{font.lineHeight.relaxed}",
      "color": "{color.accent.primary}"
    }
  }
}
